```gitignore
# Compiled and binary files
*.pyc
__pycache__/
*.class
*.o
*.obj
*.exe
*.dll
*.so
*.a
*.out

# Dependencies and virtual environments
node_modules/
venv/
.venv/
.env
.env.local
.env.*

# Build and distribution directories
dist/
build/
target/
.mypy_cache/
.pytest_cache/
.coverage
coverage/
htmlcov/

# Editor and IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# System files
.DS_Store
Thumbs.db

# Logs
*.log

# Gradle
.gradle/

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```